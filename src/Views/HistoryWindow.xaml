<Window x:Class="RemindMe.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RemindMe.Converters"
        Title="History" Height="620" Width="520" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}" FontFamily="{StaticResource AppFont}">
    <Window.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="History" Style="{StaticResource HeadingText}" FontSize="20" VerticalAlignment="Center"/>
            <TextBlock x:Name="CountText" Style="{StaticResource SubText}" Margin="10,6,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="EmptyState" Visibility="Collapsed">
                <TextBlock Text="No history yet." Style="{StaticResource SubText}" Margin="0,40,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource BillCard}" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}">
                                        <Run Text="{Binding EventLabel}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding BillName}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource SubText}"
                                               Margin="0,2,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding EventDate, StringFormat={}{0:MMM d, yyyy h:mm tt}}"
                                           Style="{StaticResource SubText}" VerticalAlignment="Top"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Clear History" Style="{StaticResource GhostPillButton}" Margin="0,0,8,0"
                    Click="ClearHistory_Click"/>
            <Button Content="Close" Style="{StaticResource PillButton}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
